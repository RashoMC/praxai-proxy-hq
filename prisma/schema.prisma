generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Lead {
  id           String     @id @default(cuid())
  company      String
  contact      String?
  email        String?
  linkedin     String?
  phone        String?
  priority     String     @default("MEDIUM")
  status       String     @default("LEAD")
  source       String?
  notes        String?
  screenshot   String?
  messageDraft String?
  messageSent  Boolean    @default(false)
  followUpAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  activities   Activity[]
}

model Activity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  note      String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Agent {
  id        String    @id @default(cuid())
  name      String    @unique
  emoji     String
  color     String
  status    String    @default("IDLE")
  task      String?
  queueSize Int       @default(0)
  lastSeen  DateTime?
  updatedAt DateTime  @updatedAt
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
}

enum TodoStatus {
  PENDING
  DONE
}

model Todo {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    TodoPriority @default(MEDIUM)
  status      TodoStatus   @default(PENDING)
  agent       String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  activities  TodoActivity[]
  notifications TodoNotification[]

  @@index([agent])
  @@index([status])
  @@index([createdAt])
}

model TodoActivity {
  id        String   @id @default(cuid())
  todoId    String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  type      String
  note      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([todoId])
  @@index([createdAt])
}

model TodoNotification {
  id        String   @id @default(cuid())
  todoId    String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  agent     String
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([todoId])
  @@index([agent])
  @@index([createdAt])
}

model CustomKpi {
  id        String   @id @default(cuid())
  name      String
  value     Json
  change    String?
  agent     String
  timestamp DateTime
  createdAt DateTime @default(now())

  @@index([agent])
  @@index([timestamp])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())
}
